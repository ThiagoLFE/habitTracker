package main

templ BaseLayout(title string, body templ.Component) {
	<!DOCTYPE html>
	<html>
		<head>
			<meta charset="UTF-8"/>
			<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
			<title>{ title } </title>
		</head>
		<body>
			@body
		</body>
	</html>
}

templ HeaderPage(title string) {
	<h1>{ title }</h1>
}
